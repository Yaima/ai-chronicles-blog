---
// Site search bar (matches the original Wix masthead search).
// Submitting sends the query to /blog, which filters the post list client-side.
---
<div class="searchbar">
  <form class="searchbar__form" role="search" action="/blog" method="get">
    <input
      type="text"
      name="q"
      class="searchbar__input"
      placeholder="Search..."
      aria-label="Search posts"
    />
    <button type="submit" class="searchbar__btn" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </button>
  </form>
</div>
