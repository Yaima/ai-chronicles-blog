---
import { SOCIAL, AUTHOR } from '../consts';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="social">
    {SOCIAL.github && <a href={SOCIAL.github} target="_blank" rel="noopener">GitHub</a>}
    {SOCIAL.linkedin && <a href={SOCIAL.linkedin} target="_blank" rel="noopener">LinkedIn</a>}
    {SOCIAL.instagram && <a href={SOCIAL.instagram} target="_blank" rel="noopener">Instagram</a>}
    {SOCIAL.email && <a href={SOCIAL.email}>Email</a>}
    <a href="/rss.xml">RSS</a>
  </div>
  <div>© {year} {AUTHOR} · AI Chronicles</div>
</footer>
