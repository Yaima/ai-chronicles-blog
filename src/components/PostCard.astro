---
import { AUTHOR } from '../consts';
import { formatDate } from '../utils';
interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  readTime: string;
  heroImage: string;
}
const { slug, title, description, pubDate, readTime, heroImage } = Astro.props;
const url = `/post/${slug}`;
---
<article class="post-card">
  <a class="post-card__media" href={url} aria-hidden="true" tabindex="-1">
    <img src={heroImage} alt={title} loading="lazy" />
  </a>
  <div class="post-card__body">
    <div class="post-meta">
      <img class="post-meta__avatar" src="/images/profile.webp" alt={AUTHOR} loading="lazy" />
      <div class="post-meta__lines">
        <div class="post-meta__name">{AUTHOR}</div>
        <div class="post-meta__sub">{formatDate(pubDate)} · {readTime}</div>
      </div>
    </div>
    <h2 class="post-card__title"><a href={url}>{title}</a></h2>
    <p class="post-card__excerpt">{description}</p>
  </div>
</article>
