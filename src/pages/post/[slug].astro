---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { AUTHOR } from '../../consts';
import { formatDate } from '../../utils';
import { slugifyCategory } from '../../categories';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;
const category = d.category;

const recent = (await getCollection('posts'))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const siteUrl = new URL('/', Astro.site).href;
const heroAbs = new URL(d.heroImage, Astro.site).href;
const published = d.pubDate.toISOString();
const modified = (d.updatedDate ?? d.pubDate).toISOString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: d.title,
  description: d.description,
  image: [heroAbs],
  datePublished: published,
  dateModified: modified,
  author: { '@type': 'Person', name: AUTHOR, url: `${siteUrl}about` },
  publisher: {
    '@type': 'Organization',
    name: 'AI Chronicles',
    logo: { '@type': 'ImageObject', url: `${siteUrl}favicon-192.png` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  articleSection: category,
  url: canonical,
};
---
<BaseLayout
  title={d.title}
  description={d.description}
  image={d.heroImage}
  type="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={published} />
    <meta property="article:modified_time" content={modified} />
    <meta property="article:author" content={AUTHOR} />
    <meta property="article:section" content={category} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>
  <article class="article">
    <a class="article__back" href="/">← All posts</a>
    {category && <a class="article__cat" href={`/category/${slugifyCategory(category)}`}>{category}</a>}
    <h1 class="article__title">{d.title}</h1>

    <div class="article__byline">
      <img class="article__avatar" src="/images/profile.webp" alt={AUTHOR} />
      <div>
        <div class="article__author">{AUTHOR}</div>
        <div class="article__meta">
          {formatDate(d.pubDate)} · {d.readTime}
          {d.updatedDate && <> · Updated {formatDate(d.updatedDate)}</>}
        </div>
      </div>
    </div>

    <figure class={`article__hero${d.heroPortrait ? ' article__hero--portrait' : ''}`}>
      <img src={d.heroImage} alt={d.title} />
      {d.heroCredit && <figcaption class="article__credit">{d.heroCredit}</figcaption>}
    </figure>

    <div class="prose">
      <Content />
    </div>
  </article>

  {recent.length > 0 && (
    <section class="more container">
      <div class="more__head">
        <h2>More posts</h2>
        <a href="/" class="more__seeall">See all</a>
      </div>
      <div class="card-grid card-grid--3">
        {recent.map((p) => (
          <BlogCard
            slug={p.id}
            title={p.data.title}
            description={p.data.description}
            pubDate={p.data.pubDate}
            readTime={p.data.readTime}
            heroImage={p.data.heroImage}
            category={p.data.category}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
